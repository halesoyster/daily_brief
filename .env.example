# daily_brief — environment variables
# ─────────────────────────────────────
# Export these before running daily-brief, or use your project's
# load_env.sh (see run.sh) to pull them from macOS Keychain.
#
# Do not commit a filled-in .env file — it is already in .gitignore.

# ── Claude API ────────────────────────────────────────────────────────────────
# console.anthropic.com → API Keys
CLAUDE_API_KEY=

# ── Email delivery (optional) ─────────────────────────────────────────────────
# Required only when running with --email.
# BRIEF_EMAIL_APP_PASSWORD is a Gmail App Password (16 chars), NOT your
# regular Gmail password. Generate at https://myaccount.google.com/apppasswords
# (requires 2FA on the Gmail account). Missing vars = graceful no-op.
BRIEF_EMAIL_FROM=
BRIEF_EMAIL_TO=
BRIEF_EMAIL_APP_PASSWORD=
